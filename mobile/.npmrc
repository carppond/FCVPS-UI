# react-native-ssh-sftp@1.0.3 declares a stale peer range (react-native ^0.54.0)
# that conflicts with this project's react-native 0.85.x under npm 7+ strict
# peer resolution. The library works fine at runtime; relax peer resolution so
# `npm install` / `expo install` / EAS build don't hard-fail on it.
legacy-peer-deps=true
