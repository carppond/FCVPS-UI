#!/usr/bin/env bash
# shiguang-vps agent installer ({{.Version}}).
#
# Usage:
#   install:   curl -fsSL "<hub>/install-agent.sh?token=<T>&agent_id=<ID>&hub_url=<HUB>" | bash
#   uninstall: curl -fsSL "<hub>/install-agent.sh?token=<T>&agent_id=<ID>" | bash -s -- --uninstall
#
# The script is rendered by the hub at request time — the TOKEN below is
# already inlined; the script does NOT need any further environment vars.
set -euo pipefail

# Uninstall mode (`… | bash -s -- --uninstall`): stop + remove the agent and
# exit. Handled before the credential guards below so it needs no valid token.
for arg in "$@"; do
  if [[ "$arg" == "--uninstall" ]]; then
    echo "==> Uninstalling shiguang-agent..."
    SUDO=""; [[ "$EUID" -ne 0 ]] && SUDO="sudo"
    if command -v systemctl >/dev/null 2>&1; then
      $SUDO systemctl disable --now shiguang-agent 2>/dev/null || true
      $SUDO rm -f /etc/systemd/system/shiguang-agent.service
      $SUDO systemctl daemon-reload 2>/dev/null || true
    fi
    $SUDO rm -f /usr/local/bin/shiguang-agent
    echo "OK: shiguang-agent uninstalled — remember to delete it in the panel too"
    exit 0
  fi
done

# Values are emitted inside single quotes so bash performs NO substitution on
# them ($... and `...` would otherwise execute inside double quotes). The
# server-side rendering layer rejects any value containing a literal '\''
# character, so this delimiter is safe.
TOKEN='{{.Token}}'
HUB_URL='{{.HubURL}}'
AGENT_ID='{{.AgentID}}'

if [[ -z "$TOKEN" ]]; then
  echo "install-agent.sh: TOKEN is empty — refusing to install" >&2
  exit 2
fi
if [[ -z "$HUB_URL" ]]; then
  echo "install-agent.sh: HUB_URL is empty — refusing to install" >&2
  exit 2
fi
if [[ -z "$AGENT_ID" ]]; then
  echo "install-agent.sh: AGENT_ID is empty — refusing to install" >&2
  exit 2
fi

# ── detect os/arch ──────────────────────────────────────────────────────────
OS="$(uname -s | tr '[:upper:]' '[:lower:]')"
ARCH_RAW="$(uname -m)"
case "$ARCH_RAW" in
  x86_64|amd64)     ARCH=amd64 ;;
  aarch64|arm64)    ARCH=arm64 ;;
  armv7l|armv7)     ARCH=armv7 ;;
  *)
    echo "install-agent.sh: unsupported architecture '$ARCH_RAW'" >&2
    exit 3
    ;;
esac

if [[ "$OS" != "linux" && "$OS" != "darwin" ]]; then
  echo "install-agent.sh: unsupported OS '$OS' (only linux/darwin)" >&2
  exit 3
fi

ASSET="agent-${OS}-${ARCH}"
TMP_BIN="$(mktemp -t shiguang-agent.XXXXXX)"

# ── download ───────────────────────────────────────────────────────────────
echo "==> Downloading ${HUB_URL}/dl/${ASSET}"
curl -fsSL "${HUB_URL}/dl/${ASSET}" -o "$TMP_BIN"
chmod +x "$TMP_BIN"

# ── install to /usr/local/bin (requires sudo on Linux) ─────────────────────
TARGET_BIN="/usr/local/bin/shiguang-agent"
if [[ "$EUID" -eq 0 ]]; then
  install -m 0755 "$TMP_BIN" "$TARGET_BIN"
else
  sudo install -m 0755 "$TMP_BIN" "$TARGET_BIN"
fi
rm -f "$TMP_BIN"
echo "==> Installed ${TARGET_BIN}"

# ── systemd unit (linux only) ──────────────────────────────────────────────
if [[ "$OS" == "linux" ]] && command -v systemctl >/dev/null 2>&1; then
  UNIT_PATH="/etc/systemd/system/shiguang-agent.service"
  UNIT_BODY=$(cat <<UNIT
[Unit]
Description=Shiguang VPS Agent
After=network.target

[Service]
ExecStart=${TARGET_BIN} -hub-url ${HUB_URL} -token ${TOKEN} -agent-id ${AGENT_ID}
Restart=always
RestartSec=5
User=root

[Install]
WantedBy=multi-user.target
UNIT
)
  if [[ "$EUID" -eq 0 ]]; then
    printf '%s\n' "$UNIT_BODY" > "$UNIT_PATH"
    systemctl daemon-reload
    systemctl enable --now shiguang-agent
  else
    printf '%s\n' "$UNIT_BODY" | sudo tee "$UNIT_PATH" >/dev/null
    sudo systemctl daemon-reload
    sudo systemctl enable --now shiguang-agent
  fi
  echo "==> shiguang-agent enabled and started via systemd"
else
  echo "==> systemd not detected; run '${TARGET_BIN} -hub-url ${HUB_URL} -token ${TOKEN} -agent-id ${AGENT_ID}' manually"
fi

echo "OK: shiguang-agent installed and running"
